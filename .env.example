# Copy this to .env and fill in your keys

# SEC EDGAR - required for 10-K/10-Q/Form 4 scraping
# Use any valid email address - no signup needed, just identifies your requests
SEC_USER_AGENT_EMAIL=your_email@example.com
SEC_USER_AGENT_NAME=LS_Equity_Research

# OpenRouter - AI analysis layer (free models available)
# Get key at: openrouter.ai
OPENROUTER_API_KEY=

# Alpaca - paper trading execution
# Get keys at: alpaca.markets -> API Keys -> Paper Trading
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Optional - paid data sources (system works without these via free fallbacks)
# FMP_API_KEY=           # Financial Modeling Prep - earnings transcripts
# POLYGON_API_KEY=       # Polygon.io - exchange-level prices
# FRED_API_KEY=          # FRED - yield curve, credit spreads
